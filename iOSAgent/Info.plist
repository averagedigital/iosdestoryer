<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>iOS Agent</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>iOS Agent uses calendar access to search events and create events you request.</string>
	<key>NSContactsUsageDescription</key>
	<string>iOS Agent uses contacts access to search and create contacts you request.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>iOS Agent records audio only after you tap record.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>iOS Agent uses photo library write access to create albums and organize photos you request.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>iOS Agent uses photo library access to inspect and organize photos you request.</string>
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>iOS Agent uses reminders access to search reminders and create reminders you request.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>iOS Agent transcribes recordings only after you request transcription.</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
</dict>
</plist>
